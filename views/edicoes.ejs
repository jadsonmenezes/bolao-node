<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin: Gerenciar Edições</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 font-sans text-slate-800 pb-12">
    <nav class="bg-slate-900 text-white p-4 shadow-md">
        <div class="container mx-auto flex justify-between items-center">
            <h1 class="text-sm font-bold">Painel de Configurações</h1>
            <div class="space-x-4 text-sm font-semibold">
                <a href="/<%= linkParams %>" class="text-slate-400 hover:text-white transition">Ranking</a>
                <a href="/apostas<%= linkParams %>" class="text-slate-400 hover:text-white transition">Apostas</a>
                <a href="/edicoes<%= linkParams %>" class="text-white border-b-2 border-white pb-1">Edições</a>
            </div>
        </div>
    </nav>

    <main class="container mx-auto p-2 sm:p-4 mt-4 max-w-6xl grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="bg-white p-4 sm:p-5 rounded-2xl shadow border col-span-1 h-fit">
            <h3 class="font-black text-slate-800 text-xs uppercase mb-3 border-b pb-1" id="titulo-form">Nova Rodada do Bolão</h3>
            <form action="/edicoes/salvar" method="POST" id="form-edicao" class="space-y-4 text-xs font-bold text-slate-500 uppercase">
                <input type="hidden" name="id" id="edicao-id" value="0">
                
                <div>
                    <label class="block mb-1 text-[10px]">Nome Comercial do Bolão</label>
                    <input type="text" name="nome_bolao" id="edicao-nome" required class="w-full bg-slate-50 border rounded-lg p-2.5 text-slate-800 text-xs">
                </div>
                <div class="grid grid-cols-2 gap-2">
                    <div>
                        <label class="block mb-1 text-[10px]">Dezenas (6 ou 10)</label>
                        <select name="qtd_dezenas" id="edicao-dezenas" class="w-full bg-slate-50 border rounded-lg p-2 text-slate-800 text-xs">
                            <option value="6">6 (Mega)</option>
                            <option value="10">10 (Tiro Curto)</option>
                        </select>
                    </div>
                    <div>
                        <label class="block mb-1 text-[10px]">Modelo de Regra</label>
                        <select name="tipo_bolao" id="edicao-tipo" class="w-full bg-slate-50 border rounded-lg p-2 text-slate-800 text-xs">
                            <option value="acumulativo">Acumulativo</option>
                            <option value="tiro_curto">Tiro Curto (Único)</option>
                        </select>
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-2">
                    <div>
                        <label class="block mb-1 text-[10px]">Data Inicial</label>
                        <input type="date" name="data_inicio" id="edicao-data" required class="w-full bg-slate-50 border rounded-lg p-2 text-slate-800 text-xs">
                    </div>
                    <div>
                        <label class="block mb-1 text-[10px]">Custo Aposta (R$)</label>
                        <input type="number" step="0.01" name="valor_aposta" id="edicao-valor" required class="w-full bg-slate-50 border rounded-lg p-2 text-slate-800 text-xs">
                    </div>
                </div>

                <div class="bg-slate-50 p-3 rounded-xl border space-y-2.5">
                    <span class="text-[9px] text-slate-400 tracking-wider font-black block border-b pb-0.5">Rateio Financeiro (%)</span>
                    <div class="grid grid-cols-2 gap-2">
                        <div><label class="text-[9px]">Admin</label><input type="number" name="pct_admin" id="edicao-p-admin" required class="w-full bg-white border rounded p-1.5 text-slate-800"></div>
                        <div><label class="text-[9px]">Principal</label><input type="number" name="pct_premio_principal" id="edicao-p-principal" required class="w-full bg-white border rounded p-1.5 text-slate-800"></div>
                        <div><label class="text-[9px]">1º Sorteio</label><input type="number" name="pct_primeiro_sorteio" id="edicao-p-sorteio" required class="w-full bg-white border rounded p-1.5 text-slate-800"></div>
                        <div><label class="text-[9px]">Quina / Vice</label><input type="number" name="pct_proximos" id="edicao-p-proximos" required class="w-full bg-white border rounded p-1.5 text-slate-800"></div>
                    </div>
                    <div><label class="text-[9px]">Doação</label><input type="number" name="pct_doacao" id="edicao-p-doacao" required class="w-full bg-white border rounded p-1.5 text-slate-800"></div>
                </div>

                <div id="bloco-clonagem">
                    <label class="block mb-1 text-[10px] text-indigo-600">Copiar jogos do bolão anterior?</label>
                    <select name="clonar_jogos" class="w-full bg-indigo-50 border border-indigo-200 rounded-lg p-2 text-indigo-900 text-xs font-black">
                        <option value="nao">Não, começar em branco</option>
                        <option value="sim">Sim, clonar base de participantes</option>
                    </select>
                </div>

                <button type="submit" class="w-full bg-slate-900 text-white py-3 rounded-xl font-black text-xs uppercase shadow-md tracking-wider">Gravar Configurações</button>
                <button type="button" onclick="resetForm()" id="btn-cancelar" class="hidden w-full bg-slate-200 text-slate-600 py-2 rounded-xl text-xs">Sair da Edição</button>
            </form>
        </div>

        <div class="bg-white p-4 sm:p-5 rounded-2xl shadow border col-span-1 lg:col-span-2">
            <h3 class="font-black text-slate-800 text-sm uppercase mb-4">Rodadas Cadastradas</h3>
            <div class="space-y-3">
                <% edicoes.forEach(ed => { %>
                    <div class="flex justify-between items-center p-3 border bg-slate-50 rounded-xl">
                        <div>
                            <span class="text-[9px] font-black uppercase px-2 py-0.5 rounded <%= ed.status === 'aberta' ? 'bg-blue-100 text-blue-700' : 'bg-red-100 text-red-700' %>"><%= ed.status %></span>
                            <h4 class="font-bold text-slate-800 text-sm mt-1">Rodada <%= ed.numero %>: <%= ed.nome_bolao %></h4>
                            <span class="text-[10px] text-slate-400 font-bold"><%= ed.qtd_dezenas %> dezenas | Regra: <%= ed.tipo_bolao %></span>
                        </div>
                        <div class="flex items-center gap-1.5 text-[10px] font-bold uppercase">
                            <button onclick="prepararEdicao('<%= ed.id %>', '<%= ed.nome_bolao %>', '<%= ed.qtd_dezenas %>', '<%= ed.tipo_bolao %>', '<%= ed.data_inicio %>', '<%= ed.valor_aposta %>', '<%= ed.pct_admin %>', '<%= ed.pct_premio_principal %>', '<%= ed.pct_primeiro_sorteio %>', '<%= ed.pct_proximos %>', '<%= ed.pct_doacao %>')" class="text-blue-600 bg-blue-50 border rounded px-2.5 py-1.5 hover:bg-blue-100">Configurar</button>
                            <form action="/edicoes/deletar/<%= ed.id %>" method="POST" onsubmit="return confirm('Mover para a lixeira por 3 dias?');">
                                <button type="submit" class="text-red-500 bg-red-50 border rounded px-2 py-1.5 hover:bg-red-100">Deletar</button>
                            </form>
                        </div>
                    </div>
                <% }) %>
            </div>

            <% if (lixeira && lixeira.length > 0) { %>
                <div class="mt-8 bg-amber-50 p-4 rounded-xl border border-amber-200">
                    <h4 class="font-black text-amber-800 text-[10px] uppercase tracking-wider mb-2.5 flex items-center gap-1">♻️ Lixeira de Segurança (Até 3 dias)</h4>
                    <div class="space-y-2">
                        <% lixeira.forEach(l => { %>
                            <div class="flex justify-between items-center text-xs bg-white p-3 rounded-xl border shadow-sm">
                                <div class="flex flex-col">
                                    <span class="font-bold text-slate-700 text-xs">Rodada <%= l.numero %> - <%= l.nome_bolao %></span>
                                    <span class="text-[9px] text-slate-400 font-bold">Excluído em: <%= new Date(l.deletado_em).toLocaleString('pt-BR') %></span>
                                </div>
                                <form action="/edicoes/restaurar/<%= l.id %>" method="POST">
                                    <button type="submit" class="bg-amber-600 text-white font-black px-3 py-1.5 rounded-lg hover:bg-amber-700 text-[9px] uppercase tracking-wider shadow-sm transition">⚡ Desfazer Exclusão</button>
                                </form>
                            </div>
                        <% }) %>
                    </div>
                </div>
            <% } %>
        </div>
    </main>

    <script>
        function prepararEdicao(id, nome, dezenas, tipo, data, valor, admin, principal, sorteio, proximos, doacao) {
            document.getElementById('titulo-form').innerText = "Alterar Configurações"; document.getElementById('edicao-id').value = id;
            document.getElementById('edicao-nome').value = nome; document.getElementById('edicao-dezenas').value = dezenas;
            document.getElementById('edicao-tipo').value = tipo; document.getElementById('edicao-data').value = data;
            document.getElementById('edicao-valor').value = valor; document.getElementById('edicao-p-admin').value = admin;
            document.getElementById('edicao-p-principal').value = principal; document.getElementById('edicao-p-sorteio').value = sorteio;
            document.getElementById('edicao-p-proximos').value = proximos; document.getElementById('edicao-p-doacao').value = doacao;
            document.getElementById('bloco-clonagem').classList.add('hidden'); document.getElementById('btn-cancelar').classList.remove('hidden');
        }
        function resetForm() {
            document.getElementById('titulo-form').innerText = "Nova Rodada do Bolão"; document.getElementById('form-edicao').reset();
            document.getElementById('edicao-id').value = "0"; document.getElementById('bloco-clonagem').classList.remove('hidden');
            document.getElementById('btn-cancelar').classList.add('hidden');
        }
    </script>
</body>
</html>
