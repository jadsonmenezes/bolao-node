<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8"><title>Acesso Administrativo</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-900 h-screen flex items-center justify-center p-4 font-sans">
    <div class="bg-white p-8 rounded-2xl shadow-2xl w-full max-w-sm border border-slate-100">
        <h2 class="text-2xl font-black text-center text-slate-800 mb-2">Painel do Organizador</h2>
        <p class="text-center text-xs text-slate-400 font-semibold uppercase tracking-wider mb-6">Autenticação Requerida</p>
        
        <% if (erro) { %>
            <div class="text-red-600 bg-red-50 text-xs font-bold text-center p-2.5 rounded-lg border border-red-200 mb-4">
                Usuário ou Senha Inválidos! Tente novamente.
            </div>
        <% } %>
        
        <form action="/login" method="POST" class="space-y-4">
            <div>
                <label class="block text-slate-400 font-bold text-[10px] uppercase tracking-widest mb-1">Usuário</label>
                <input type="text" name="username" required placeholder="ex: admin" class="w-full bg-slate-50 border border-slate-200 rounded-lg p-3 outline-none focus:ring-2 focus:ring-slate-900 text-center font-bold text-slate-800">
            </div>

            <div>
                <label class="block text-slate-400 font-bold text-[10px] uppercase tracking-widest mb-1">Chave de Acesso</label>
                <input type="password" name="senha" required placeholder="••••••••" class="w-full bg-slate-50 border border-slate-200 rounded-lg p-3 outline-none focus:ring-2 focus:ring-slate-900 text-center font-bold">
            </div>
            
            <button type="submit" class="w-full bg-slate-900 hover:bg-black text-white font-bold py-3 rounded-lg text-sm uppercase tracking-wider transition shadow-lg">Autenticar</button>
        </form>
        
        <div class="mt-6 text-center border-t pt-4">
            <a href="/" class="text-xs font-bold text-slate-400 hover:text-slate-600 uppercase tracking-wider">Voltar ao Painel Aberto</a>
        </div>
    </div>
</body>
</html>
